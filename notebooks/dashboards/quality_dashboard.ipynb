# Jupyter Notebook - Run this to see quality metrics

import pandas as pd
import matplotlib.pyplot as plt
import json
from pathlib import Path

# Load metrics
metrics_dir = Path("data/monitoring")

# Read retrieval metrics
retrieval_data = []
with open(metrics_dir / "retrieval_metrics.jsonl") as f:
    for line in f:
        retrieval_data.append(json.loads(line))

df_retrieval = pd.DataFrame(retrieval_data)

# Plots
fig, axes = plt.subplots(2, 2, figsize=(12, 10))

# Plot 1: Recall over time
axes[0, 0].plot(df_retrieval['timestamp'], df_retrieval['recall@5'])
axes[0, 0].axhline(y=0.80, color='r', linestyle='--', label='Target: 80%')
axes[0, 0].set_title('Recall@5 Over Time')
axes[0, 0].set_ylabel('Recall')

# Plot 2: Precision over time
axes[0, 1].plot(df_retrieval['timestamp'], df_retrieval['precision@5'])
axes[0, 1].axhline(y=0.60, color='r', linestyle='--', label='Target: 60%')
axes[0, 1].set_title('Precision@5 Over Time')
axes[0, 1].set_ylabel('Precision')

# Plot 3: Latency over time
axes[1, 0].plot(df_retrieval['timestamp'], df_retrieval['latency_seconds'])
axes[1, 0].axhline(y=5, color='r', linestyle='--', label='Target: <5s')
axes[1, 0].set_title('Query Latency Over Time')
axes[1, 0].set_ylabel('Latency (seconds)')

# Plot 4: Summary stats
summary_data = {
    'Recall': f"{df_retrieval['recall@5'].mean():.1%}",
    'Precision': f"{df_retrieval['precision@5'].mean():.1%}",
    'Avg Latency': f"{df_retrieval['latency_seconds'].mean():.2f}s"
}
axes[1, 1].axis('off')
axes[1, 1].text(0.5, 0.5, str(summary_data), ha='center', va='center', fontsize=12)

plt.tight_layout()
plt.savefig('data/monitoring/quality_dashboard.png')
plt.show()

print("✓ Quality Dashboard Generated")